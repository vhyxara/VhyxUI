{
  "name": "@vhyxui/core",
  "version": "0.1.0-alpha.1",
  "description": "VhyxUI core — shared types, contracts, slot, and error infrastructure",
  "license": "MIT",
  "private": false,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./contracts": {
      "import": "./dist/contracts.js",
      "require": "./dist/contracts.cjs",
      "types": "./dist/contracts.d.ts"
    },
    "./slot": {
      "import": "./dist/slot.js",
      "require": "./dist/slot.cjs",
      "types": "./dist/slot.d.ts"
    },
    "./errors": {
      "import": "./dist/errors.js",
      "require": "./dist/errors.cjs",
      "types": "./dist/errors.d.ts"
    },
    "./types": {
      "import": "./dist/types.js",
      "require": "./dist/types.cjs",
      "types": "./dist/types.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --project tsconfig.test.json --noEmit",
    "lint": "eslint src"
  },
  "dependencies": {
    "@vhyxseal/core": "1.0.0-rc.2"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0"
  }
}
