      "types": "./dist/test-utils.d.ts"
    },
    "./style.css": "./style.css"
  },
  "sideEffects": ["*.css", "dist/style.css"],
  "files": [
    "dist",
    "style.css"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --project tsconfig.test.json --noEmit",
    "lint": "eslint src"
  },
  "dependencies": {
    "@vhyxseal/react": "1.0.0-rc.2",
