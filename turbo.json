{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "sync": {
      "cache": false,
      "inputs": ["src/**/*.css"]
    },
    "@vhyxui/core#build": {
      "dependsOn": ["@vhyxui/tokens#sync", "^build"],
      "outputs": ["dist/**"]
    },
    "@vhyxui/react#build": {
      "dependsOn": ["@vhyxui/tokens#sync", "^build"],
      "outputs": ["dist/**"]
    },
    "test": {
      "dependsOn": ["build"]
    },
    "typecheck": {
      "dependsOn": ["build"]
    },
    "lint": {},
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
